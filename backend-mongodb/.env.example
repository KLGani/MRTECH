# MongoDB Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
# Example: mongodb+srv://username:password@cluster.mongodb.net/edupredict
MONGODB_URI=mongodb://localhost:27017/edupredict

# Server Port
PORT=5000

# JWT Secret Key (Change this to a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-123456789

# Node Environment
NODE_ENV=development
